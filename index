    const cmpBranches=(selVal==='__ALL__'
      ? allBranches.filter(b=>reports.filter(r=>r.branch===b).length>=2)
      : [selVal]).filter(b=>reports.filter(r=>r.branch===b).length>=2);

    // Pre-compute stats for all branches
    const allStats=cmpBranches.map(b=>{
      const br=reports.filter(r=>r.branch===b);
      br.sort((a,x)=>(a.createdAt?.seconds||0)-(x.createdAt?.seconds||0));
      const first=br[0], last=br[br.length-1];
