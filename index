// ══════════════════════════════════════════
// Excel Export — Full (Overview)
// ══════════════════════════════════════════
function exportExcel(){
  if(!reports.length){showToast('لا توجد بيانات','err');return;}
  const wb=XLSX.utils.book_new();
  const totalP=reports.reduce((s,r)=>s+(Number(r.total)||0),0);
  const totalA=reports.reduce((s,r)=>s+(Number(r.arabi)||0),0);
  const avg=totalP>0?((totalA/totalP)*100).toFixed(1):0;
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['نظام نسب عرض العربي','','','',''],
    ['تاريخ التصدير',new Date().toLocaleString('ar-EG'),'','',''],['','','','',''],
    ['إجمالي التقارير','إجمالي المنتجات','منتجات العربي','نسبة العربي','عدد الفروع'],
    [reports.length,totalP,totalA,avg+'%',branches.length]
  ]),'ملخص');
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['#','الفرع','المندوب','الإجمالي','العربي','النسبة %','التاريخ'],
    ...reports.map((r,i)=>[i+1,r.branch,r.agent,r.total,r.arabi,parseFloat(r.pct),r.timestamp])
  ]),'التقارير');
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['الفرع','التقارير','الإجمالي','العربي','النسبة','التقييم'],
    ...branches.map(b=>{
      const br=reports.filter(r=>r.branch===b);
      const t=br.reduce((s,r)=>s+(Number(r.total)||0),0);
      const a=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
      const p=t>0?((a/t)*100).toFixed(1):0;
      return[b,br.length,t,a,parseFloat(p),p>=50?'ممتاز':p>=30?'جيد':'يحتاج تحسين'];
    })
  ]),'تحليل الفروع');
  // ورقة تحليل الأقسام لكل فرع على حدة
  branches.forEach(b=>{
    const br=reports.filter(r=>r.branch===b);
    const rows=calcSections(br);
    if(!rows.length)return;
    const sheetName=('أقسام-'+b).slice(0,31); // Excel max 31 chars
    const tot=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const arab=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const bpct=tot>0?((arab/tot)*100).toFixed(1):0;
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
      ['تحليل أقسام فرع: '+b,'','','',''],
      ['إجمالي الفرع',tot,'منتجات العربي',arab,'النسبة: '+bpct+'%'],
      ['','','','',''],
      ['القسم','الإجمالي','العربي','النسبة %','التقييم'],
      ...rows.map(s=>[s.l,s.count,s.arabi,parseFloat(s.p),parseFloat(s.p)>=50?'ممتاز':parseFloat(s.p)>=30?'جيد':'يحتاج تحسين'])
    ]),sheetName);
  });
  // ورقة إجمالية للأقسام (جميع الفروع مجمّعة)
  const allSec=calcSections(reports);
  if(allSec.length){
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
      ['تحليل الأقسام الإجمالي — جميع الفروع','','','',''],
      ['','','','',''],
      ['القسم','الإجمالي','العربي','النسبة %','التقييم'],
      ...allSec.map(s=>[s.l,s.count,s.arabi,parseFloat(s.p),parseFloat(s.p)>=50?'ممتاز':parseFloat(s.p)>=30?'جيد':'يحتاج تحسين'])
    ]),'تحليل الأقسام-إجمالي');
  }
  XLSX.writeFile(wb,`تقرير_نسب_العرض_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.xlsx`);
  showToast('تم تحميل Excel بنجاح ✓');
}

