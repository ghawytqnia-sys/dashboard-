    sf.addText('نظام نسب عرض العربي — تقرير تلقائي شامل',{x:.8,y:2.3,w:8.4,h:.45,fontSize:14,color:MT,align:'center',rtlMode:true});
    sf.addText(`الفروع: ${branches.length}  |  التقارير: ${reports.length}  |  المتوسط: ${avgPct}%`,
      {x:.8,y:3,w:8.4,h:.35,fontSize:12,color:MT,align:'center',rtlMode:true});
    sf.addShape(pptx.ShapeType.rect,{x:3,y:3.6,w:4,h:.5,fill:{color:DARK},line:{color:BLUE,pt:1}});
    sf.addText(new Date().toLocaleDateString('ar-EG'),{x:3,y:3.65,w:4,h:.4,fontSize:13,color:CYAN,bold:true,align:'center'});

    const fname=`تقرير_نسب_العرض_الشامل_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.pptx`;
    await pptx.writeFile({fileName:fname});
    showToast('✅ تم تحميل PowerPoint بنجاح ('+pptx.slides?.length+' شرائح)');
  }catch(err){
    console.error('PPT Error:',err);
    showToast('خطأ في إنشاء PowerPoint: '+err.message,'err');
  }finally{
    btn.classList.remove('loading');
    btn.innerHTML='📊 PowerPoint<span class="progress-bar" id="pptProgress"></span>';
  }
}

