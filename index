  renderBranchCards(branches,'branchGrid',false);
  renderSecTable('secTable');
  setTimeout(()=>{
    renderBarChart();
    renderDonutChart(totalA,totalP-totalA);
    animateBars();
  },80);
}

// ══════════════════════════════════════════
// Reports Page
// ══════════════════════════════════════════
function renderReportsPage(){
  const c=document.getElementById('content');
  if(!reports.length){
    c.innerHTML=`<div class="empty fi"><div class="ei">📭</div><h3>لا توجد تقارير</h3><p>لا توجد بيانات بعد</p></div>`;
    return;
  }
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  c.innerHTML=`
    <div class="page-title fi"><h2>📋 جميع التقارير</h2><p>${reports.length} تقرير مُسجَّل</p></div>
