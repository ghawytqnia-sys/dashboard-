    <th>القسم</th><th>الإجمالي</th><th>العربي</th><th>النسبة</th><th>التقييم</th>
  </tr></thead><tbody>${rows.map(s=>{
    const cls=parseFloat(s.p)>=50?'high':parseFloat(s.p)>=30?'mid':'low';
    const stars=parseFloat(s.p)>=70?'⭐⭐⭐':parseFloat(s.p)>=50?'⭐⭐':parseFloat(s.p)>=30?'⭐':'—';
    return`<tr><td><strong>${s.l}</strong></td>
      <td style="text-align:center">${s.count}</td>
