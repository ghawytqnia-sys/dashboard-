function onCmpBranchChange(){
  const b=document.getElementById('cmpBranchSel')?.value;
  const bSel=document.getElementById('cmpBeforeSel');
  const aSel=document.getElementById('cmpAfterSel');
  const bLbl=document.getElementById('cmpBeforeLabel');
  const aLbl=document.getElementById('cmpAfterLabel');
  const runBtn=document.getElementById('cmpRunBtn');
  const res=document.getElementById('cmpResult');
  if(!bSel||!aSel)return;

  if(b==='__ALL__'){
    // Hide before/after selectors — show all-branches view
    bSel.style.display='none'; aSel.style.display='none';
    if(bLbl)bLbl.style.display='none';
    if(aLbl)aLbl.style.display='none';
    if(runBtn)runBtn.textContent='🌐 عرض تقرير كل الفروع';
    if(res)res.innerHTML='';
    // Immediately render all-branches full analysis
    renderAllBranchesFullReport();
    return;
  }

  // Single branch mode
  bSel.style.display=''; aSel.style.display='';
  if(bLbl)bLbl.style.display='';
  if(aLbl)aLbl.style.display='';
  if(runBtn)runBtn.textContent='⚡ عرض المقارنة';

  bSel.innerHTML='<option value="">— اختر —</option>';
  aSel.innerHTML='<option value="">— اختر —</option>';
  if(!b)return;
  const br=reports.filter(r=>r.branch===b).map((r,i)=>({...r,_idx:i}));
  br.sort((a,b2)=>(a.createdAt?.seconds||0)-(b2.createdAt?.seconds||0));
  br.forEach((r,i)=>{
    const label=`${i+1}. ${r.agent||'-'} — ${r.pct||0}% — ${r.timestamp||''}`;
    bSel.innerHTML+=`<option value="${r._docId||r.id||i}">${label}</option>`;
    aSel.innerHTML+=`<option value="${r._docId||r.id||i}">${label}</option>`;
  });
  if(br.length>=2){ bSel.selectedIndex=1; aSel.selectedIndex=br.length; }
  if(res)res.innerHTML='';
}

function getReportByKey(branch, key){
  const br=reports.filter(r=>r.branch===branch);
  br.sort((a,b)=>(a.createdAt?.seconds||0)-(b.createdAt?.seconds||0));
  return br.find(r=>(r._docId||r.id||br.indexOf(r))===key
    || String(r._docId)===String(key)
    || String(r.id)===String(key)
  ) || br[0];
}

function runComparison(){
  const branch=document.getElementById('cmpBranchSel')?.value;
  if(branch==='__ALL__'){ renderAllBranchesFullReport(); return; }
  const beforeKey=document.getElementById('cmpBeforeSel')?.value;
  const afterKey=document.getElementById('cmpAfterSel')?.value;
  if(!branch||!beforeKey||!afterKey){showToast('اختر الفرع والتقريرين','err');return;}
  if(beforeKey===afterKey){showToast('اختر تقريرين مختلفين','err');return;}

  const br=reports.filter(r=>r.branch===branch);
  br.sort((a,b)=>(a.createdAt?.seconds||0)-(b.createdAt?.seconds||0));
  const rB=br.find(r=>String(r._docId||r.id)===String(beforeKey)||br.indexOf(r)===parseInt(beforeKey));
  const rA=br.find(r=>String(r._docId||r.id)===String(afterKey)||br.indexOf(r)===parseInt(afterKey));
  if(!rB||!rA){showToast('لم يُعثر على التقرير','err');return;}

  const pB=parseFloat(rB.pct)||0, pA=parseFloat(rA.pct)||0;
  const delta=+(pA-pB).toFixed(1);
  const up=delta>0, same=delta===0;
