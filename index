}
function lsClearAlert() { document.getElementById('lsAlert').style.display='none'; }
function lsShowResetAlert(msg,type) {
  const el=document.getElementById('lsResetAlert');
  const icons={err:'❌',ok:'✅'};
  document.getElementById('lsRAIcon').textContent=icons[type]||'⚠️';
  document.getElementById('lsRAMsg').textContent=msg;
