    sf.addText('نظام نسب عرض العربي — تقرير المقارنة الشامل',{x:.6,y:2.5,w:8.8,h:.48,fontSize:14,color:MT,align:'center',rtlMode:true});
    sf.addShape(pptx.ShapeType.rect,{x:1.2,y:3.1,w:7.6,h:.96,fill:{color:DARK2},line:{color:BLUE,pt:.8}});
    [
      ['الفروع',String(cmpBranches.length),CYAN,1.4],
      ['تحسّن',String(improved),GREEN,3.0],
      ['تراجع',String(declined),RED,4.6],
      ['ثابت',String(stable),MT,6.2],
    ].forEach(([l,v,col,x])=>{
      sf.addText(v,{x,y:3.18,w:1.5,h:.4,fontSize:22,bold:true,color:col,align:'center'});
      sf.addText(l,{x,y:3.6,w:1.5,h:.3,fontSize:10,color:MT,align:'center',rtlMode:true});
    });
    sf.addShape(pptx.ShapeType.rect,{x:0,y:5.57,w:'100%',h:.03,fill:{color:BLUE}});
    sf.addText(new Date().toLocaleDateString('ar-EG')+'  |  نظام نسب عرض العربي',
      {x:.3,y:5.62,w:9.4,h:.25,fontSize:9,color:MT,rtlMode:true,align:'center'});

    const fname=`المقارنة_الشاملة_${selVal==='__ALL__'?'كل_الفروع':selVal}_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.pptx`;
    await pptx.writeFile({fileName:fname});
    showToast(`✅ تم تحميل PowerPoint المقارنة (${pptx.slides?.length} شرائح)`);
  }catch(e){console.error(e);showToast('خطأ: '+e.message,'err');}
  finally{setPPTLoading(false);}
}

// Helper — PPT loading state
function setPPTLoading(on){
  const btn=document.getElementById('pptBtn');
  const lbl=document.getElementById('pptBtnLabel');
  if(on){btn.classList.add('loading');if(lbl)lbl.textContent='⏳ جاري الإنشاء...';}
  else{btn.classList.remove('loading');updateExportButtons(currentPage);}
}

