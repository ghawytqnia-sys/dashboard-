// Auth — Logout
// ══════════════════════════════════════════
function lsLogout(){
  if(!confirm('هل تريد تسجيل الخروج؟')) return;
  localStorage.removeItem('arabi_auth_session');
  // Show login screen
  const ls=document.getElementById('loginScreen');
  if(ls){
    ls.style.display='flex';
    document.getElementById('lsEmail').value='';
    document.getElementById('lsPass').value='';
    document.getElementById('lsAlert').style.display='none';
    document.getElementById('lsEmailErr').style.display='none';
    document.getElementById('lsPassErr').style.display='none';
  }
  showToast('👋 تم تسجيل الخروج');
}

