        <div class="kpi-sub">منتج مُسجَّل</div></div>
      <div class="kpi-card yellow"><div class="kpi-icon">⭐</div>
        <div class="kpi-label">منتجات العربي</div><div class="kpi-value">${totalA}</div>
        <div class="kpi-sub">وحدة معروضة</div></div>
      <div class="kpi-card dyn"><div class="kpi-icon">📊</div>
        <div class="kpi-label">متوسط نسبة العربي</div><div class="kpi-value">${avgPct}%</div>
        <div class="kpi-sub">${kpiLabel}</div></div>
    </div>
    <div class="charts-row fi">
      <div class="chart-card">
        <div class="chart-title">📈 نسب العرض حسب التقارير</div>
        <div class="chart-wrap"><canvas id="barChart"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">🍩 توزيع المنتجات</div>
        <div class="chart-wrap"><canvas id="donutChart"></canvas></div>
      </div>
    </div>
    <div class="sec-header fi"><h2>🏢 ملخص الفروع (${branches.length} فرع)</h2>
      <button class="filter-reset" onclick="switchPage('branches', document.querySelector('[data-page=branches]'))">عرض التحليل الكامل ←</button>
