function exportExcelBranches(){
  if(!reports.length){showToast('لا توجد بيانات','err');return;}
  const wb=XLSX.utils.book_new();
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  const focusBranch=selectedBranch||null;

  // ملخص مقارنة الفروع
  const branchData=branches.map(b=>{
    const br=reports.filter(r=>r.branch===b);
    const t=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const a=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const p=t>0?((a/t)*100).toFixed(1):0;
    return{b,len:br.length,t,a,p:parseFloat(p)};
  }).sort((x,y)=>y.p-x.p);

  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['تحليل الفروع'+(focusBranch?' — تركيز على: '+focusBranch:''),'','','','',''],
    ['تاريخ التصدير',new Date().toLocaleString('ar-EG'),'','','',''],['','','','','',''],
    ['الترتيب','الفرع','التقارير','الإجمالي','العربي','النسبة %','التقييم'],
    ...branchData.map((r,i)=>[i+1,r.b,r.len,r.t,r.a,r.p,r.p>=50?'ممتاز':r.p>=30?'جيد':'يحتاج تحسين'])
  ]),'ترتيب الفروع');

  // ورقة لكل فرع
  const targetBranches=focusBranch?[focusBranch]:branches;
  targetBranches.forEach(b=>{
    const br=reports.filter(r=>r.branch===b);
    br.sort((a,x)=>(a.createdAt?.seconds||0)-(x.createdAt?.seconds||0));
    const shName=b.slice(0,31);
    const rows=[
      ['فرع: '+b,'','','',''],
      ['عدد التقارير',br.length,'','',''],
      ['','','','',''],
      ['#','المندوب','الإجمالي','العربي','النسبة %','التاريخ'],
      ...br.map((r,i)=>[i+1,r.agent,r.total,r.arabi,parseFloat(r.pct),r.timestamp]),
      ['','','','',''],
      ['— أقسام الفرع —','','','',''],
      ['القسم','الإجمالي','العربي','النسبة %',''],
    ];
    const secs=calcSections(br);
    secs.forEach(s=>rows.push([s.l,s.count,s.arabi,parseFloat(s.p),'']));
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),shName);
  });

  const fname=`الفروع${focusBranch?'_'+focusBranch:''}_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.xlsx`;
  XLSX.writeFile(wb,fname);
  showToast('تم تحميل Excel الفروع ✓');
}

