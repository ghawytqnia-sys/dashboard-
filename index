      <td style="text-align:center"><span class="pbadge ${cls}">${s.p}%</span></td>
      <td style="text-align:center">${stars}</td></tr>`;
  }).join('')}</tbody></table>`;
}

function renderSecTable(containerId, branchFilter){
  const c=document.getElementById(containerId);if(!c)return;
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];

  // إذا تم تحديد فرع بعينه
  if(branchFilter){
    const rows=calcSections(reports.filter(r=>r.branch===branchFilter));
    c.innerHTML=rows.length
      ? buildSecTableHTML(rows)
      : `<p style="color:var(--tm);text-align:center;padding:14px">لا توجد بيانات أقسام للفرع "${branchFilter}"</p>`;
    return;
  }

  // عرض أقسام كل فرع على حدة
  let hasAny=false, html='';
  branches.forEach(b=>{
    const br=reports.filter(r=>r.branch===b);
    const rows=calcSections(br);
    if(!rows.length)return;
    hasAny=true;
    const tot=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const arab=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const pct=tot>0?((arab/tot)*100).toFixed(1):0;
    const col=parseFloat(pct)>=50?'var(--g1)':parseFloat(pct)>=30?'var(--y1)':'var(--r1)';
    html+=`
      <div style="margin-bottom:22px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;padding:10px 14px;
          background:rgba(14,165,233,.06);border-radius:10px;border-right:3px solid var(--p)">
          <span style="font-size:14px;font-weight:700;color:var(--ac2)">🏢 ${b}</span>
          <span style="margin-right:auto;font-size:12px;color:${col};font-weight:700">نسبة الفرع: ${pct}%</span>
          <span style="font-size:11px;color:var(--tm)">${rows.length} قسم</span>
        </div>
        ${buildSecTableHTML(rows)}
      </div>`;
  });
  c.innerHTML=hasAny?html:'<p style="color:var(--tm);text-align:center;padding:20px">لا توجد بيانات أقسام</p>';
}
