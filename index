        <th>الترتيب</th><th>الفرع</th><th>التقارير</th><th>الإجمالي</th><th>العربي</th><th>النسبة</th><th>التقييم</th><th>تحليل</th>
      </tr></thead><tbody id="branchTblBody"></tbody></table>
