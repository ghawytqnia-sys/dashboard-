    // Sections per branch
    for(const b of branches){
      const secs=calcSections(reports.filter(r=>r.branch===b));
      if(!secs.length)continue;
      const ss=pptx.addSlide();ss.background={color:BG};
      addHdr(ss,'أقسام فرع: '+b);
      const sh=t2=>({text:t2,options:{bold:true,color:WH,fill:{color:'0d1f3a'},fontSize:11}});
      const stbl=[[sh('القسم'),sh('الإجمالي'),sh('العربي'),sh('النسبة %'),sh('التقييم')]];
      secs.forEach(s=>{
        const sc2=parseFloat(s.p)>=50?GREEN:parseFloat(s.p)>=30?YELLOW:RED;
        stbl.push([
          {text:s.l,options:{color:WH,rtlMode:true,fontSize:11}},
          {text:String(s.count),options:{color:MT,align:'center',fontSize:11}},
          {text:String(s.arabi),options:{color:MT,align:'center',fontSize:11}},
          {text:s.p+'%',options:{color:sc2,bold:true,align:'center',fontSize:12}},
          {text:parseFloat(s.p)>=50?'ممتاز':parseFloat(s.p)>=30?'جيد':'تحسين',options:{color:sc2,align:'center',rtlMode:true,fontSize:10}},
        ]);
      });
      ss.addTable(stbl,{x:.3,y:.68,w:9.4,rowH:.36,fontSize:11,border:{type:'solid',color:'0ea5e9',pt:.4}});
    }

    await pptx.writeFile({fileName:`الإحصائيات_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.pptx`});
    showToast('✅ تم تحميل PowerPoint الإحصائيات');
  }catch(e){showToast('خطأ: '+e.message,'err');}
  finally{setPPTLoading(false);}
}

