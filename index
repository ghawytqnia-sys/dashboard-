      <div class="kpi-card blue"><div class="kpi-icon">📋</div>
        <div class="kpi-label">إجمالي التقارير</div><div class="kpi-value">${reports.length}</div>
        <div class="kpi-sub">تقرير مُرسَل</div></div>
      <div class="kpi-card green"><div class="kpi-icon">📦</div>
