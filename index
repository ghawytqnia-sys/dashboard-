      sl.addText('نظام نسب عرض العربي  |  تقرير المقارنة  |  '+new Date().toLocaleDateString('ar-EG'),
        {x:.3,y:5.62,w:9.4,h:.25,fontSize:8,color:MT,rtlMode:true,align:'center'});
    };

    const allBranches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
