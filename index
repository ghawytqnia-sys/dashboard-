function switchPage(page, el){
  currentPage=page;
  selectedBranch=null;
  document.querySelectorAll('.nav-item').forEach(i=>i.classList.remove('active'));
  if(el) el.classList.add('active');
  const h=document.getElementById('pageHeading');
  const dot=page==='overview'?'<span class="dot-live"></span>':'';
  h.innerHTML=pageTitles[page]+' '+dot;
  updateExportButtons(page);
  renderCurrentPage();
  closeSb();
}

// ── تحديث أزرار التصدير حسب التبويب ──
const pageExportLabels = {
  overview:    { excel:'📥 تصدير عام',        ppt:'📊 تقرير عام' },
  reports:     { excel:'📥 تصدير التقارير',   ppt:'📊 عرض التقارير' },
  branches:    { excel:'📥 تصدير الفروع',     ppt:'📊 عرض الفروع' },
  statistics:  { excel:'📥 تصدير الإحصائيات',ppt:'📊 عرض الإحصائيات' },
  comparison:  { excel:'📥 تصدير المقارنة',   ppt:'📊 عرض المقارنة' },
};
function updateExportButtons(page){
  const labels = pageExportLabels[page] || pageExportLabels.overview;
  const excelBtn = document.getElementById('excelBtn');
  const pptLabel = document.getElementById('pptBtnLabel');
  if(excelBtn) excelBtn.innerHTML = labels.excel;
  if(pptLabel) pptLabel.textContent = labels.ppt;
}
function renderCurrentPage(){
  document.getElementById('lastUpdate').textContent='آخر تحديث: '+new Date().toLocaleTimeString('ar-EG');
  if(currentPage==='overview') renderOverview();
  else if(currentPage==='reports') renderReportsPage();
  else if(currentPage==='branches') renderBranchesPage();
  else if(currentPage==='statistics') renderStatisticsPage();
  else if(currentPage==='comparison') renderComparisonPage();
}

// ══════════════════════════════════════════
// Overview Page
// ══════════════════════════════════════════
function renderOverview(){
  const c=document.getElementById('content');
  if(!reports.length){
    c.innerHTML=`<div class="empty fi"><div class="ei">📭</div><h3>لا توجد تقارير بعد</h3><p>أرسل تقريراً من صفحة تسجيل نسب العرض ليظهر هنا فوراً</p></div>`;
    return;
  }
  const totalP=reports.reduce((s,r)=>s+(Number(r.total)||0),0);
  const totalA=reports.reduce((s,r)=>s+(Number(r.arabi)||0),0);
  const avgPct=totalP>0?((totalA/totalP)*100).toFixed(1):0;
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  const kpiLabel=avgPct>=50?'🟢 ممتاز':avgPct>=30?'🟡 جيد':'🔴 يحتاج تحسين';

  c.innerHTML=`
