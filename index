      </tr></thead><tbody id="repBody"></tbody></table>
    </div>
  `;
  filterReportsTable();
}
function filterReportsTable(){
  const filter=document.getElementById('repBranchFilter')?.value||'';
  const filtered=filter?reports.filter(r=>r.branch===filter):reports;
  const tb=document.getElementById('repBody');if(!tb)return;
  const cnt=document.getElementById('repFilterCount');
  if(cnt)cnt.textContent=filter?`${filtered.length} تقرير للفرع "${filter}"`:'';
  tb.innerHTML='';
  filtered.forEach((r,i)=>{
    const p=parseFloat(r.pct)||0;
    const cls=p>=50?'high':p>=30?'mid':'low';
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>${i+1}</td><td><strong>${r.branch||'-'}</strong></td><td>${r.agent||'-'}</td>
      <td style="text-align:center">${r.total||0}</td>
      <td style="text-align:center">${r.arabi||0}</td>
      <td style="text-align:center"><span class="pbadge ${cls}">${r.pct||0}%</span></td>
