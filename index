<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>لوحة التحكم — نسب عرض العربي</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
// Load PptxGenJS with fallback
(function(){
  var urls=[
    'https://cdn.jsdelivr.net/npm/pptxgenjs@3.12.0/dist/pptxgen.bundle.js',
    'https://unpkg.com/pptxgenjs@3.12.0/dist/pptxgen.bundle.js',
    'https://cdnjs.cloudflare.com/ajax/libs/pptxgenjs/3.12.0/pptxgen.bundle.js'
  ];
  var idx=0;
  function tryLoad(){
    if(idx>=urls.length)return;
    var s=document.createElement('script');
    s.src=urls[idx++];
    s.onerror=tryLoad;
    document.head.appendChild(s);
  }
  tryLoad();
})();
</script>
<style>
:root{
  --p:#0ea5e9;--pd:#0284c7;--pl:#38bdf8;
  --ac:#06b6d4;--ac2:#67e8f9;
  --bg:#060e1e;--bg2:#0a1628;--bg3:#0f2040;
  --glass:rgba(14,165,233,.07);--gb:rgba(14,165,233,.22);--gs:rgba(14,165,233,.14);
  --tx:#e0f2fe;--tm:#7dd3fc;
  --r:14px;--rs:10px;
  --g1:#34d399;--g2:#10b981;
  --y1:#fbbf24;--y2:#f59e0b;
  --r1:#f87171;--r2:#ef4444;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Cairo','Tajawal',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 70% 50% at 10% 10%,rgba(6,182,212,.1) 0%,transparent 55%),
             radial-gradient(ellipse 50% 70% at 90% 90%,rgba(14,165,233,.08) 0%,transparent 55%),
             linear-gradient(170deg,#060e1e 0%,#09152a 60%,#06101e 100%);pointer-events:none}
body::after{content:'';position:fixed;inset:0;z-index:0;
  background-image:linear-gradient(rgba(14,165,233,.03) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(14,165,233,.03) 1px,transparent 1px);
  background-size:50px 50px;pointer-events:none}
.app{position:relative;z-index:1;display:flex;min-height:100vh}

/* ── Sidebar ── */
.sidebar{width:260px;min-height:100vh;background:rgba(6,14,30,.95);border-left:1px solid var(--gb);backdrop-filter:blur(24px);display:flex;flex-direction:column;padding:20px 0;flex-shrink:0;transition:transform .3s;z-index:50}
.sb-logo{padding:0 20px 18px;border-bottom:1px solid var(--gb);margin-bottom:10px}
.sb-logo .icon{font-size:32px;filter:drop-shadow(0 0 12px var(--p))}
.sb-logo h2{font-size:14px;font-weight:900;background:linear-gradient(135deg,var(--ac2),var(--p));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-top:5px;line-height:1.4}
.sb-logo p{font-size:11px;color:var(--tm);margin-top:2px}
.fb-status{display:flex;align-items:center;gap:8px;padding:8px 20px 12px;font-size:11px;font-weight:700;color:var(--tm)}
.fb-dot{width:8px;height:8px;border-radius:50%;background:#6b7280;flex-shrink:0;transition:background .4s}
.fb-dot.ok{background:#10b981;box-shadow:0 0 6px #10b981;animation:fbp 2s infinite}
.fb-dot.err{background:#ef4444}
@keyframes fbp{0%,100%{opacity:1}50%{opacity:.3}}
.nav-section{padding:6px 20px 4px;font-size:10px;font-weight:700;color:rgba(125,211,252,.4);letter-spacing:1.5px;text-transform:uppercase;margin-top:6px}
.nav-item{display:flex;align-items:center;gap:11px;padding:11px 20px;color:var(--tm);font-size:13px;font-weight:600;cursor:pointer;border-right:3px solid transparent;transition:all .2s;user-select:none}
.nav-item:hover{background:var(--glass);color:var(--tx)}
.nav-item.active{background:linear-gradient(90deg,rgba(14,165,233,.15),transparent);color:var(--pl);border-right-color:var(--p)}
.nav-item .ni{font-size:16px;width:20px;text-align:center}
.nav-badge{margin-right:auto;background:var(--pd);color:#fff;font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px}
.sb-footer{margin-top:auto;padding:16px 20px;border-top:1px solid var(--gb);font-size:10px;color:var(--tm);text-align:center;line-height:1.6}

/* ── Main ── */
.main{flex:1;overflow-x:hidden;display:flex;flex-direction:column}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 26px;background:rgba(6,14,30,.85);border-bottom:1px solid var(--gb);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:10px}
.topbar h1{font-size:clamp(14px,2.2vw,18px);font-weight:900;background:linear-gradient(135deg,var(--ac2),var(--pl));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.topbar-sub{font-size:11px;color:var(--tm);margin-top:2px}
.topbar-actions{display:flex;gap:8px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border:none;border-radius:50px;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:transform .2s,box-shadow .2s;white-space:nowrap}
.btn-excel{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;box-shadow:0 4px 14px rgba(22,163,74,.3)}
.btn-excel:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(22,163,74,.4)}
.btn-ppt{background:linear-gradient(135deg,#7c2d12,#c2410c);color:#fff;box-shadow:0 4px 14px rgba(194,65,12,.3)}
.btn-ppt:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(194,65,12,.4)}
.btn-clear{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:#fca5a5}
.btn-clear:hover{background:rgba(239,68,68,.22)}
.hamburger{display:none;background:none;border:none;color:var(--tx);font-size:22px;cursor:pointer;padding:4px}
@media(max-width:768px){
  .hamburger{display:block}
  .sidebar{position:fixed;top:0;right:0;transform:translateX(100%)}
  .sidebar.open{transform:translateX(0)}
  .sb-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:49}
  .sb-overlay.show{display:block}
  .content{padding:16px 12px}
}
.content{padding:24px 26px;flex:1}

/* ── Page sections ── */
.page{display:none}.page.active{display:block}

/* ── KPI ── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:450px){.kpi-grid{grid-template-columns:1fr}}
.kpi-card{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:18px;position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s}
.kpi-card:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(14,165,233,.18)}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi-card.blue::before{background:linear-gradient(90deg,var(--pd),var(--ac2))}
.kpi-card.green::before{background:linear-gradient(90deg,#065f46,#10b981)}
.kpi-card.yellow::before{background:linear-gradient(90deg,#78350f,#f59e0b)}
.kpi-card.dyn::before{background:linear-gradient(90deg,#1d4ed8,#06b6d4)}
.kpi-label{font-size:11px;color:var(--tm);font-weight:600;margin-bottom:6px}
.kpi-value{font-size:clamp(22px,3vw,32px);font-weight:900;line-height:1}
.kpi-card.blue .kpi-value{color:var(--ac2)}
.kpi-card.green .kpi-value{color:#34d399}
.kpi-card.yellow .kpi-value{color:#fbbf24}
.kpi-card.dyn .kpi-value{background:linear-gradient(135deg,var(--ac2),var(--pl));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.kpi-sub{font-size:10px;color:var(--tm);margin-top:5px}
.kpi-icon{position:absolute;top:12px;left:12px;font-size:24px;opacity:.2}

/* ── Charts ── */
.charts-row{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;margin-bottom:22px}
@media(max-width:800px){.charts-row{grid-template-columns:1fr}}
.chart-card{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:18px}
.chart-title{font-size:13px;font-weight:700;color:var(--tm);margin-bottom:12px;display:flex;align-items:center;gap:7px}
.chart-wrap{position:relative;height:210px}

/* ── Table ── */
.tbl-card{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:18px;margin-bottom:20px;overflow-x:auto}
.tbl-title{font-size:14px;font-weight:700;color:var(--ac2);margin-bottom:14px}
table.dt{width:100%;border-collapse:collapse;font-size:13px;min-width:600px}
table.dt th{background:rgba(14,165,233,.12);color:var(--tm);font-weight:700;padding:10px 12px;text-align:right;border-bottom:1px solid var(--gb);white-space:nowrap}
table.dt td{padding:10px 12px;border-bottom:1px solid rgba(14,165,233,.07);transition:background .15s;white-space:nowrap}
table.dt tr:hover td{background:rgba(14,165,233,.05)}
table.dt tr:last-child td{border-bottom:none}
.pbadge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700}
.pbadge.high{background:rgba(16,185,129,.15);color:#34d399}
.pbadge.mid{background:rgba(245,158,11,.15);color:#fbbf24}
.pbadge.low{background:rgba(239,68,68,.15);color:#f87171}
.del-btn{background:none;border:none;color:#f87171;cursor:pointer;font-size:14px;padding:3px 7px;border-radius:6px;transition:background .15s}
.del-btn:hover{background:rgba(239,68,68,.15)}

/* ── Branch cards ── */
.branch-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px;margin-bottom:22px}
.bcard{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:18px;position:relative;overflow:hidden;cursor:pointer;transition:transform .2s,box-shadow .2s,border-color .2s}
.bcard:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(14,165,233,.2);border-color:var(--p)}
.bcard.selected{border-color:var(--p);background:rgba(14,165,233,.12);box-shadow:0 0 20px rgba(14,165,233,.2)}
.bcard::before{content:'';position:absolute;top:0;right:0;width:3px;height:100%;background:linear-gradient(180deg,var(--p),var(--ac))}
.bcard-name{font-size:14px;font-weight:700;color:var(--ac2);margin-bottom:10px;display:flex;align-items:center;gap:7px}
.bcard-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px}
.bs-v{font-size:17px;font-weight:900;color:var(--tx);text-align:center}
.bs-l{font-size:10px;color:var(--tm);text-align:center}
.bbar{height:6px;background:rgba(14,165,233,.12);border-radius:20px;overflow:hidden;margin-bottom:5px}
.bbar-fill{height:100%;border-radius:20px;background:linear-gradient(90deg,var(--pd),var(--ac2));width:0%;transition:width 1.1s cubic-bezier(.4,0,.2,1)}
.bbar-pcts{font-size:10px;color:var(--tm);display:flex;justify-content:space-between}

/* ── Branch filter bar ── */
.branch-filter-bar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px;padding:14px 18px;background:var(--glass);border:1px solid var(--gb);border-radius:var(--r)}
.branch-filter-bar label{font-size:12px;font-weight:700;color:var(--tm);white-space:nowrap}
.branch-filter-bar select{background:rgba(14,165,233,.1);border:1px solid var(--gb);border-radius:8px;color:var(--tx);font-family:'Cairo',sans-serif;font-size:13px;padding:7px 12px;outline:none;cursor:pointer;transition:border-color .2s;min-width:200px}
.branch-filter-bar select:focus{border-color:var(--p)}
.filter-reset{background:rgba(14,165,233,.12);border:1px solid var(--gb);border-radius:8px;color:var(--tm);font-family:'Cairo',sans-serif;font-size:12px;padding:7px 14px;cursor:pointer;transition:all .2s}
.filter-reset:hover{background:rgba(14,165,233,.22);color:var(--tx)}

/* ── Branch detail panel ── */
.branch-detail{background:var(--glass);border:1px solid var(--p);border-radius:var(--r);padding:22px;margin-bottom:22px;animation:fadeIn .3s ease}
.branch-detail-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.branch-detail-title{font-size:18px;font-weight:900;color:var(--ac2);display:flex;align-items:center;gap:8px}
.branch-close-btn{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:#fca5a5;font-family:'Cairo',sans-serif;font-size:12px;padding:6px 14px;border-radius:8px;cursor:pointer;transition:all .2s}
.branch-close-btn:hover{background:rgba(239,68,68,.25)}
.branch-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px}
@media(max-width:700px){.branch-kpis{grid-template-columns:repeat(2,1fr)}}
.bkpi{background:rgba(14,165,233,.06);border:1px solid rgba(14,165,233,.15);border-radius:10px;padding:14px;text-align:center}
.bkpi-val{font-size:24px;font-weight:900;color:var(--ac2)}
.bkpi-lbl{font-size:10px;color:var(--tm);margin-top:4px}
.branch-charts-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px}
@media(max-width:700px){.branch-charts-row{grid-template-columns:1fr}}

/* ── Statistics page ── */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:22px}
@media(max-width:900px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.stats-grid{grid-template-columns:1fr}}
.stat-card{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:18px;position:relative;overflow:hidden}
.stat-card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.stat-card-title{font-size:13px;font-weight:700;color:var(--tm)}
.stat-card-icon{font-size:22px;opacity:.4}
.stat-rank{display:flex;flex-direction:column;gap:8px}
.rank-item{display:flex;align-items:center;gap:10px}
.rank-num{width:22px;height:22px;border-radius:50%;background:rgba(14,165,233,.15);color:var(--ac2);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.rank-name{flex:1;font-size:12px;font-weight:600;color:var(--tx)}
.rank-val{font-size:12px;font-weight:700;color:var(--ac2)}
.rank-bar-wrap{flex:1;height:4px;background:rgba(14,165,233,.1);border-radius:10px;overflow:hidden}
.rank-bar-fill{height:100%;background:linear-gradient(90deg,var(--pd),var(--ac2));border-radius:10px;transition:width 1s ease}
.timeline-item{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid rgba(14,165,233,.06)}
.timeline-item:last-child{border-bottom:none}
.tl-dot{width:8px;height:8px;border-radius:50%;background:var(--p);flex-shrink:0;margin-top:5px}
.tl-info{flex:1}
.tl-branch{font-size:12px;font-weight:700;color:var(--tx)}
.tl-detail{font-size:11px;color:var(--tm);margin-top:2px}
.tl-pct{font-size:13px;font-weight:700;flex-shrink:0;margin-top:2px}

/* ── Section header ── */
.sec-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px}
.sec-header h2{font-size:15px;font-weight:700;color:var(--ac2);display:flex;align-items:center;gap:7px}
.dot-live{width:8px;height:8px;border-radius:50%;background:#10b981;box-shadow:0 0 5px #10b981;display:inline-block;animation:dl 2s infinite}
@keyframes dl{0%,100%{opacity:1}50%{opacity:.3}}

/* ── Page title ── */
.page-title{margin-bottom:20px}
.page-title h2{font-size:20px;font-weight:900;color:var(--ac2);display:flex;align-items:center;gap:8px}
.page-title p{font-size:12px;color:var(--tm);margin-top:4px}

/* ── Empty/Loading ── */
.empty{text-align:center;padding:60px 20px;color:var(--tm)}
.empty .ei{font-size:56px;opacity:.35;margin-bottom:14px}
.empty h3{font-size:17px;font-weight:700;color:var(--tx);margin-bottom:6px}
.empty p{font-size:13px;opacity:.65}
.loading-state{text-align:center;padding:50px 20px}
.lds{display:inline-block;width:36px;height:36px;border:3px solid rgba(14,165,233,.2);border-top-color:var(--p);border-radius:50%;animation:spin .7s linear infinite;margin-bottom:12px}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Toast ── */
.toast{position:fixed;bottom:22px;right:22px;background:linear-gradient(135deg,#065f46,#059669);border:1px solid rgba(16,185,129,.4);border-radius:12px;padding:12px 20px;color:#fff;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;display:flex;align-items:center;gap:9px;box-shadow:0 8px 28px rgba(16,185,129,.4);transform:translateY(100px);opacity:0;transition:transform .4s cubic-bezier(.34,1.56,.64,1),opacity .3s;z-index:9999;pointer-events:none;max-width:320px}
.toast.err{background:linear-gradient(135deg,#7f1d1d,#ef4444);border-color:rgba(239,68,68,.4)}
.toast.show{transform:translateY(0);opacity:1}

/* ── Progress bar in PPT btn ── */
.btn-ppt.loading{pointer-events:none;opacity:.7}
.progress-bar{display:none;height:2px;background:linear-gradient(90deg,var(--p),var(--ac2));border-radius:2px;position:absolute;bottom:0;left:0;animation:pbarAnim 1.5s infinite}
@keyframes pbarAnim{0%{left:0%;width:30%}50%{left:35%;width:40%}100%{left:70%;width:30%}}

/* ── Comparison Page ── */
.cmp-filter{display:flex;align-items:center;gap:12px;flex-wrap:wrap;padding:16px 20px;background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);margin-bottom:22px}
.cmp-filter label{font-size:12px;font-weight:700;color:var(--tm);white-space:nowrap}
.cmp-filter select{background:rgba(14,165,233,.1);border:1px solid var(--gb);border-radius:8px;color:var(--tx);font-family:'Cairo',sans-serif;font-size:13px;padding:7px 12px;outline:none;cursor:pointer;min-width:180px}
.cmp-filter select:focus{border-color:var(--p)}
.cmp-run-btn{background:linear-gradient(135deg,#1d4ed8,#0ea5e9);border:none;border-radius:8px;color:#fff;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;padding:8px 20px;cursor:pointer;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 14px rgba(14,165,233,.3)}
.cmp-run-btn:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(14,165,233,.4)}
.cmp-hero{display:grid;grid-template-columns:1fr auto 1fr;gap:0;margin-bottom:22px;align-items:stretch}
@media(max-width:700px){.cmp-hero{grid-template-columns:1fr}}
.cmp-side{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:22px;position:relative;overflow:hidden}
.cmp-side.before{border-color:rgba(248,113,113,.3)}
.cmp-side.after{border-color:rgba(52,211,153,.3)}
.cmp-side-tag{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:14px}
.cmp-side.before .cmp-side-tag{background:rgba(248,113,113,.15);color:#f87171}
.cmp-side.after .cmp-side-tag{background:rgba(52,211,153,.15);color:#34d399}
.cmp-side-title{font-size:16px;font-weight:700;color:var(--tm);margin-bottom:4px}
.cmp-side-date{font-size:11px;color:var(--tm);opacity:.7;margin-bottom:16px}
.cmp-big-pct{font-size:52px;font-weight:900;line-height:1;margin-bottom:6px}
.cmp-side.before .cmp-big-pct{color:#f87171}
.cmp-side.after .cmp-big-pct{color:#34d399}
.cmp-meta-row{display:flex;gap:16px;margin-top:14px;flex-wrap:wrap}
.cmp-meta{text-align:center}
.cmp-meta-v{font-size:18px;font-weight:700;color:var(--tx)}
.cmp-meta-l{font-size:10px;color:var(--tm)}
.cmp-arrow{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 12px;gap:8px}
.cmp-delta-box{background:var(--glass);border:1px solid var(--gb);border-radius:var(--r);padding:14px 18px;text-align:center;min-width:110px}
.cmp-delta-val{font-size:28px;font-weight:900}
.cmp-delta-lbl{font-size:11px;color:var(--tm);margin-top:4px}
.cmp-delta-arrow{font-size:32px}
.cmp-sections-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:22px}
