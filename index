function exportExcelReports(){
  if(!reports.length){showToast('لا توجد بيانات','err');return;}
  const wb=XLSX.utils.book_new();
  const filter=document.getElementById('repBranchFilter')?.value||'';
  const filtered=filter?reports.filter(r=>r.branch===filter):reports;
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];

  // ملخص
  const totalP=filtered.reduce((s,r)=>s+(Number(r.total)||0),0);
  const totalA=filtered.reduce((s,r)=>s+(Number(r.arabi)||0),0);
  const avg=totalP>0?((totalA/totalP)*100).toFixed(1):0;
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['تقرير التقارير'+(filter?' — فرع: '+filter:''),'','',''],
    ['تاريخ التصدير',new Date().toLocaleString('ar-EG'),'',''],
    ['','','',''],
    ['عدد التقارير','إجمالي المنتجات','منتجات العربي','النسبة'],
    [filtered.length,totalP,totalA,avg+'%']
  ]),'ملخص');

  // جدول التقارير
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
    ['#','الفرع','المندوب','الإجمالي','العربي','النسبة %','التاريخ'],
    ...filtered.map((r,i)=>[i+1,r.branch,r.agent,r.total,r.arabi,parseFloat(r.pct),r.timestamp])
  ]),'التقارير'+(filter?'-'+filter:''));

  // أقسام لكل تقرير
  filtered.forEach((r,i)=>{
    const secs=r.sections||[];
    if(!secs.length)return;
    const shName=('تقرير'+(i+1)+'-'+r.branch).slice(0,31);
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([
      ['التقرير رقم '+(i+1),'الفرع: '+r.branch,'المندوب: '+r.agent,'التاريخ: '+r.timestamp,'النسبة: '+r.pct+'%'],
      ['','','','',''],
      ['القسم','الإجمالي','العربي','النسبة %',''],
      ...secs.map(s=>{const p=s.count>0?((s.arabi/s.count)*100).toFixed(1):0;return[s.label,s.count,s.arabi,parseFloat(p),''];})
    ]),shName);
  });

  const fname=`تقارير${filter?'_'+filter:''}_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.xlsx`;
  XLSX.writeFile(wb,fname);
  showToast('تم تحميل Excel التقارير ✓');
}

