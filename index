// ── Helper: حساب أقسام مجموعة تقارير ──
function calcSections(reps){
  const smap={};
  reps.forEach(r=>(r.sections||[]).forEach(s=>{
    if(!smap[s.label])smap[s.label]={l:s.label,count:0,arabi:0};
    smap[s.label].count+=Number(s.count)||0;
    smap[s.label].arabi+=Number(s.arabi)||0;
  }));
  return Object.values(smap).sort((a,b)=>b.arabi-a.arabi).map(s=>({
    ...s, p: s.count>0?((s.arabi/s.count)*100).toFixed(1):'0'
  }));
}

function buildSecTableHTML(rows){
  if(!rows.length) return '<p style="color:var(--tm);text-align:center;padding:14px">لا توجد بيانات أقسام</p>';
