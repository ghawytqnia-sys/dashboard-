      </div>

      <!-- Sections comparison -->
      ${secCmpRows.length?`
      <div class="sec-header"><h2>📦 مقارنة الأقسام تفصيلياً</h2></div>
      <div class="cmp-sec-card" style="margin-bottom:22px">
        <div style="display:flex;gap:18px;margin-bottom:14px;font-size:11px;font-weight:700">
