<script>
// ══════════════════════════════════════════════════
// Firebase REST API — تعمل مع file:// و content://
// ══════════════════════════════════════════════════
const LS_API_KEY = 'AIzaSyAmzZoKM_YGQAlxHdj6N-s4iUegBrJKNAk';
const LS_PROJECT = 'display-a3abe';
const LS_AUTH    = 'https://identitytoolkit.googleapis.com/v1/accounts';
const LS_FS      = `https://firestore.googleapis.com/v1/projects/${LS_PROJECT}/databases/(default)/documents`;
const LS_SESSION = 'arabi_auth_session';

// تسجيل دخول بالبريد وكلمة المرور
async function lsFbSignIn(email, password) {
  const r = await fetch(`${LS_AUTH}:signInWithPassword?key=${LS_API_KEY}`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({email, password, returnSecureToken:true})
  });
  const d = await r.json();
  if (!r.ok) throw {code: d.error?.message || 'UNKNOWN'};
  return d;
}

// تجديد التوكن المنتهي
async function lsFbRefresh(refreshToken) {
  const r = await fetch(`https://securetoken.googleapis.com/v1/token?key=${LS_API_KEY}`, {
    method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body: `grant_type=refresh_token&refresh_token=${encodeURIComponent(refreshToken)}`
  });
  const d = await r.json();
  if (!r.ok) throw d;
  return d;
}

// جلب بروفايل المستخدم من Firestore
async function lsFbGetProfile(uid, idToken) {
  try {
    const r = await fetch(`${LS_FS}/users/${uid}`, {headers:{'Authorization':'Bearer '+idToken}});
    if (!r.ok) return null;
    const d = await r.json();
    const f = d.fields || {};
    return {name: f.name?.stringValue||'', role: f.role?.stringValue||'agent', branch: f.branch?.stringValue||'—'};
  } catch(e) { return null; }
}

// إرسال بريد استعادة كلمة المرور
async function lsFbReset(email) {
  const r = await fetch(`${LS_AUTH}:sendOobCode?key=${LS_API_KEY}`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({requestType:'PASSWORD_RESET', email})
  });
  const d = await r.json();
  if (!r.ok) throw {code: d.error?.message||'UNKNOWN'};
}

// حفظ الجلسة
function lsSaveSession(auth, profile) {
  const s = {
    uid: auth.localId, email: auth.email,
    name: profile?.name || auth.displayName || auth.email,
    role: profile?.role || 'agent',
    idToken: auth.idToken, refreshToken: auth.refreshToken,
    expires: Date.now() + parseInt(auth.expiresIn)*1000,
    profile: profile || {}
  };
  localStorage.setItem(LS_SESSION, JSON.stringify(s));
  return s;
}

function lsLoadSession() {
  try { return JSON.parse(localStorage.getItem(LS_SESSION)); } catch(e) { return null; }
}

function lsClearSession() { localStorage.removeItem(LS_SESSION); }

// ══ فحص الجلسة عند التحميل ══
async function lsCheckSession() {
  const s = lsLoadSession();
  if (!s) return; // لا يوجد جلسة → أبقِ شاشة الدخول

  if (Date.now() < s.expires - 60000) {
    // التوكن ما زال صالحاً
    lsEnterDashboard();
    return;
  }

  // التوكن منتهي → جدّده
  if (s.refreshToken) {
    try {
      const ref = await lsFbRefresh(s.refreshToken);
      s.idToken = ref.id_token;
      s.refreshToken = ref.refresh_token;
      s.expires = Date.now() + parseInt(ref.expires_in)*1000;
      localStorage.setItem(LS_SESSION, JSON.stringify(s));
      lsEnterDashboard();
    } catch(e) { lsClearSession(); }
  }
}

// ══ تسجيل الدخول ══
async function lsDoLogin() {
  lsClearAlert();
  const email = document.getElementById('lsEmail').value.trim();
  const pass  = document.getElementById('lsPass').value;
  let ok = true;
  if (!email || !lsIsEmail(email)) { lsShowFErr('lsEmailErr','lsEmailErrTxt','بريد إلكتروني غير صحيح'); ok=false; } else lsHideFErr('lsEmailErr');
  if (!pass) { lsShowFErr('lsPassErr','lsPassErrTxt','أدخل كلمة المرور'); ok=false; } else lsHideFErr('lsPassErr');
  if (!ok) return;

  lsSetLoading(true);
  try {
    const auth = await lsFbSignIn(email, pass);
    const profile = await lsFbGetProfile(auth.localId, auth.idToken);
    lsSaveSession(auth, profile);
    lsShowTransition();
    setTimeout(lsEnterDashboard, 1200);
  } catch(e) {
    lsSetLoading(false);
    lsShowAlert(lsFbErr(e.code), 'err');
  }
}

// ══ إظهار شاشة الانتقال ثم إخفاء Login ══
function lsShowTransition() {
  const t = document.getElementById('lsTransition');
  t.style.display = 'flex';
}


// إظهار معلومات المستخدم في الشاشة الجانبية
function lsShowUserInSidebar(){
  try{
    const s=JSON.parse(localStorage.getItem('arabi_auth_session')||'null');
    if(!s)return;
    const el=document.getElementById('sbUserInfo');
    const nm=document.getElementById('sbUserName');
    const em=document.getElementById('sbUserEmail');
    const rl=document.getElementById('sbUserRole');
    if(!el)return;
    el.style.display='block';
    if(nm)nm.textContent='👤 '+(s.name||s.email||'—');
    if(em)em.textContent=s.email||'';
    const roleMap={admin:'🛡️ مدير النظام',supervisor:'👔 مشرف',agent:'👤 مندوب'};
    const roleCls={admin:'background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.3)',supervisor:'background:rgba(14,165,233,.15);color:#67e8f9;border:1px solid rgba(14,165,233,.3)',agent:'background:rgba(52,211,153,.15);color:#34d399;border:1px solid rgba(52,211,153,.3)'};
    const role=s.role||'agent';
