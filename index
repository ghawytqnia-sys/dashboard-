function drawCmpCharts(br, rB, rA){
  // Line chart — full timeline
  const ctx1=document.getElementById('cmpLineChart');
  if(ctx1){
    if(cmpCharts.line)cmpCharts.line.destroy();
    const labels=br.map((r,i)=>`${i+1}.${r.agent||'—'}`);
    const data=br.map(r=>parseFloat(r.pct)||0);
    const ptColors=br.map(r=>{
      const isB=String(r._docId||r.id)===String(document.getElementById('cmpBeforeSel')?.value);
      const isA=String(r._docId||r.id)===String(document.getElementById('cmpAfterSel')?.value);
      return isB?'rgba(248,113,113,1)':isA?'rgba(52,211,153,1)':'rgba(14,165,233,.8)';
    });
    const ptSize=br.map(r=>{
      const isB=String(r._docId||r.id)===String(document.getElementById('cmpBeforeSel')?.value);
      const isA=String(r._docId||r.id)===String(document.getElementById('cmpAfterSel')?.value);
      return(isB||isA)?8:4;
    });
    cmpCharts.line=new Chart(ctx1,{type:'line',
      data:{labels,datasets:[{
        label:'نسبة العربي %',data,
        borderColor:'rgba(14,165,233,.8)',backgroundColor:'rgba(14,165,233,.06)',
        pointBackgroundColor:ptColors,pointRadius:ptSize,
        borderWidth:2,tension:.3,fill:true
      }]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.raw}%`}}},
        scales:{y:{beginAtZero:true,max:100,ticks:{callback:v=>v+'%',color:'rgba(125,211,252,.8)',font:{size:10}},grid:{color:'rgba(14,165,233,.06)'}},
                x:{ticks:{color:'rgba(125,211,252,.8)',font:{size:9}},grid:{display:false}}}}});
  }
  // Bar chart — before vs after products
  const ctx2=document.getElementById('cmpBarChart2');
  if(ctx2){
    if(cmpCharts.bar2)cmpCharts.bar2.destroy();
    cmpCharts.bar2=new Chart(ctx2,{type:'bar',
      data:{
        labels:['إجمالي المنتجات','منتجات العربي','نسبة العربي %'],
        datasets:[
          {label:'قبل',data:[rB.total||0,rB.arabi||0,parseFloat(rB.pct)||0],
            backgroundColor:'rgba(248,113,113,.7)',borderRadius:6,borderSkipped:false},
          {label:'بعد',data:[rA.total||0,rA.arabi||0,parseFloat(rA.pct)||0],
            backgroundColor:'rgba(52,211,153,.7)',borderRadius:6,borderSkipped:false}
        ]
      },
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'top',labels:{color:'rgba(125,211,252,.9)',font:{size:11},usePointStyle:true}}},
        scales:{y:{beginAtZero:true,ticks:{color:'rgba(125,211,252,.8)',font:{size:10}},grid:{color:'rgba(14,165,233,.06)'}},
                x:{ticks:{color:'rgba(125,211,252,.8)',font:{size:10}},grid:{display:false}}}}});
  }
}


