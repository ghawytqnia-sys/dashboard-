function lsOpenReset() {
  document.getElementById('lsResetEmail').value = document.getElementById('lsEmail').value;
  document.getElementById('lsResetAlert').style.display = 'none';
  document.getElementById('lsResetModal').style.display = 'flex';
}
function lsCloseReset() { document.getElementById('lsResetModal').style.display = 'none'; }

async function lsDoReset() {
  const email = document.getElementById('lsResetEmail').value.trim();
  if (!email || !lsIsEmail(email)) { lsShowResetAlert('أدخل بريداً إلكترونياً صحيحاً','err'); return; }
  document.getElementById('lsResetBtn').disabled = true;
  document.getElementById('lsResetBtnTxt').textContent = '';
  document.getElementById('lsResetSpinner').style.display = 'block';
  try {
    await lsFbReset(email);
    lsShowResetAlert('✅ تم الإرسال! تحقق من بريدك.','ok');
    setTimeout(lsCloseReset, 3000);
  } catch(e) {
    lsShowResetAlert(lsFbErr(e.code),'err');
  } finally {
    document.getElementById('lsResetBtn').disabled = false;
    document.getElementById('lsResetBtnTxt').textContent = '📨 إرسال رابط الاستعادة';
    document.getElementById('lsResetSpinner').style.display = 'none';
  }
}

