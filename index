        <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px">
          ${br.map((r,i)=>{
            const pp=parseFloat(r.pct)||0;
            const prev=i>0?parseFloat(br[i-1].pct)||0:null;
            const chg=prev!==null?+(pp-prev).toFixed(1):null;
