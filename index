function lsFbErr(code) {
  const m={
    'EMAIL_NOT_FOUND':'لا يوجد حساب بهذا البريد الإلكتروني',
    'INVALID_PASSWORD':'كلمة المرور غير صحيحة',
    'INVALID_LOGIN_CREDENTIALS':'البريد أو كلمة المرور غير صحيحة',
    'INVALID_EMAIL':'البريد الإلكتروني غير صحيح',
    'USER_DISABLED':'هذا الحساب موقوف، تواصل مع المسؤول',
    'TOO_MANY_ATTEMPTS_TRY_LATER':'تم تجاوز عدد المحاولات، انتظر قليلاً',
    'NETWORK_ERROR':'خطأ في الشبكة، تحقق من الاتصال بالإنترنت',
  };
  for(const k of Object.keys(m)) if(String(code).includes(k)) return m[k];
  return 'حدث خطأ: '+(code||'غير معروف');
}

