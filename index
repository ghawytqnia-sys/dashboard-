            <div class="cmp-sec-delta" style="color:${dc}">${ds}${s.d}%</div>
          </div>`;
        }).join('')}
      </div>`:''}

      <!-- Full timeline for this branch -->
      <div class="sec-header"><h2>🕐 جميع تقارير الفرع — ${branch}</h2></div>
      <div class="cmp-timeline">
        ${br.map((r,i)=>{
          const pp=parseFloat(r.pct)||0;
          const prev=i>0?parseFloat(br[i-1].pct)||0:null;
          const chg=prev!==null?+(pp-prev).toFixed(1):null;
          const isB=String(r._docId||r.id)===String(beforeKey)||br.indexOf(r)===parseInt(beforeKey);
          const isA=String(r._docId||r.id)===String(afterKey)||br.indexOf(r)===parseInt(afterKey);
