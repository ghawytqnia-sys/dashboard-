// ══════════════════════════════════════════
// Delete / Clear
// ══════════════════════════════════════════
async function deleteOne(docId,localId){
  if(!confirm('حذف هذا التقرير؟'))return;
  try{
    if(docId&&db){await db.collection('reports').doc(docId).delete();}
    else{
      let arr=JSON.parse(localStorage.getItem('arabi_reports')||'[]');
      arr=arr.filter(r=>r.id!==localId);
      localStorage.setItem('arabi_reports',JSON.stringify(arr));
      reports=arr.map(r=>({_docId:null,...r}));
      renderCurrentPage();
    }
    showToast('تم حذف التقرير');
  }catch(e){showToast('خطأ في الحذف','err');}
}
async function clearAll(){
  if(!confirm('مسح جميع التقارير نهائياً؟'))return;
  try{
    if(db){const snap=await db.collection('reports').get();const batch=db.batch();snap.forEach(d=>batch.delete(d.ref));await batch.commit();}
    else{localStorage.removeItem('arabi_reports');reports=[];renderCurrentPage();}
    showToast('تم مسح جميع التقارير');
  }catch(e){showToast('خطأ في المسح','err');}
}

// ══════════════════════════════════════════
// Toast
// ══════════════════════════════════════════
let _tt=null;
function showToast(msg,type='success'){
  const t=document.getElementById('toast');
  if(_tt){clearTimeout(_tt);t.classList.remove('show');void t.offsetWidth;}
  t.textContent=(type==='success'?'✅ ':'❌ ')+msg;
  t.className='toast'+(type==='err'?' err':'');
  void t.offsetWidth;t.classList.add('show');
  _tt=setTimeout(()=>{t.classList.remove('show');_tt=null;},3500);
}

