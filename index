    const pb=sb.count>0?((sb.arabi/sb.count)*100).toFixed(1):'0';
    const pa=sa.count>0?((sa.arabi/sa.count)*100).toFixed(1):'0';
    const d=+(parseFloat(pa)-parseFloat(pb)).toFixed(1);
    return{lbl,sb,sa,pb,pa,d};
  }).sort((a,b)=>Math.abs(b.d)-Math.abs(a.d));

  const maxSecPct=Math.max(...secCmpRows.map(s=>Math.max(parseFloat(s.pb),parseFloat(s.pa))),1);

  const res=document.getElementById('cmpResult');
  if(!res)return;
  res.innerHTML=`
    <div class="fi" style="margin-bottom:22px">
      <!-- Hero comparison -->
      <div class="cmp-hero">
        <div class="cmp-side before">
          <div class="cmp-side-tag">📅 قبل</div>
          <div class="cmp-side-title">${rB.agent||'—'}</div>
          <div class="cmp-side-date">${rB.timestamp||''}</div>
          <div class="cmp-big-pct">${pB}%</div>
          <div class="cmp-meta-row">
            <div class="cmp-meta"><div class="cmp-meta-v">${rB.total||0}</div><div class="cmp-meta-l">إجمالي</div></div>
            <div class="cmp-meta"><div class="cmp-meta-v">${rB.arabi||0}</div><div class="cmp-meta-l">العربي</div></div>
            <div class="cmp-meta"><div class="cmp-meta-v">${secsB.length}</div><div class="cmp-meta-l">أقسام</div></div>
          </div>
        </div>
        <div class="cmp-arrow">
          <div class="cmp-delta-arrow">${deltaIcon}</div>
          <div class="cmp-delta-box">
            <div class="cmp-delta-val" style="color:${deltaCol}">${deltaSign}${delta}%</div>
            <div class="cmp-delta-lbl">${up?'تحسّن':same?'ثابت':'تراجع'}</div>
          </div>
          <div style="font-size:10px;color:var(--tm);text-align:center;max-width:90px">فرع<br><strong style="color:var(--ac2)">${branch}</strong></div>
        </div>
        <div class="cmp-side after">
          <div class="cmp-side-tag">✅ بعد</div>
          <div class="cmp-side-title">${rA.agent||'—'}</div>
          <div class="cmp-side-date">${rA.timestamp||''}</div>
          <div class="cmp-big-pct">${pA}%</div>
          <div class="cmp-meta-row">
            <div class="cmp-meta"><div class="cmp-meta-v">${rA.total||0}</div><div class="cmp-meta-l">إجمالي</div></div>
            <div class="cmp-meta"><div class="cmp-meta-v">${rA.arabi||0}</div><div class="cmp-meta-l">العربي</div></div>
            <div class="cmp-meta"><div class="cmp-meta-v">${secsA.length}</div><div class="cmp-meta-l">أقسام</div></div>
          </div>
        </div>
      </div>

      <!-- Insights banner -->
      <div style="background:${up?'rgba(52,211,153,.08)':same?'rgba(14,165,233,.08)':'rgba(248,113,113,.08)'};border:1px solid ${deltaCol}33;border-radius:var(--r);padding:14px 18px;margin-bottom:22px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <span style="font-size:22px">${up?'🎯':same?'📊':'⚠️'}</span>
        <div>
          <div style="font-size:13px;font-weight:700;color:${deltaCol}">
            ${up?`تحسّن بمقدار ${delta}% منذ التقرير الأول`:same?'النسبة ثابتة دون تغيير':`تراجع بمقدار ${Math.abs(delta)}% منذ التقرير الأول`}
          </div>
          <div style="font-size:11px;color:var(--tm);margin-top:3px">
            ${up?'الأداء في تحسّن مستمر — استمر في هذا المسار':same?'لم يطرأ تغيير — راجع الأقسام الضعيفة':'يُنصح بمراجعة الفرع واتخاذ إجراءات تصحيحية'}
          </div>
        </div>
        <div style="margin-right:auto;text-align:center">
          <div style="font-size:24px;font-weight:900;color:${deltaCol}">${deltaSign}${delta}%</div>
          <div style="font-size:10px;color:var(--tm)">الفرق</div>
        </div>
      </div>

      <!-- Charts row -->
      <div class="cmp-chart-row">
        <div class="chart-card">
          <div class="chart-title">📈 مسار النسبة عبر جميع التقارير</div>
          <div class="chart-wrap"><canvas id="cmpLineChart"></canvas></div>
