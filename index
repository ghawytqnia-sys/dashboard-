// ══════════════════════════════════════════
// Excel — تبويب المقارنة
// ══════════════════════════════════════════
function exportExcelComparison(){
  if(!reports.length){showToast('لا توجد بيانات','err');return;}
  const selVal=document.getElementById('cmpBranchSel')?.value||'__ALL__';
  const wb=XLSX.utils.book_new();
  const allBranches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  const targetBranches=selVal==='__ALL__'
    ? allBranches.filter(b=>reports.filter(r=>r.branch===b).length>=2)
    : (allBranches.includes(selVal)?[selVal]:[]);

  // ═══ ورقة الملخص ═══
  const summaryRows=[
    ['تقرير المقارنة — نسب عرض العربي','','','','','',''],
    ['تاريخ التصدير',new Date().toLocaleString('ar-EG'),'','','','',''],
    ['الفروع المُصدَّرة',targetBranches.length,'','','','',''],
    ['','','','','','',''],
    ['الفرع','عدد التقارير','أول نسبة (قبل)','آخر نسبة (بعد)','التغيير','المتوسط الكلي','الحكم']
  ];
  targetBranches.forEach(b=>{
    const br=reports.filter(r=>r.branch===b);
    br.sort((a,x)=>(a.createdAt?.seconds||0)-(x.createdAt?.seconds||0));
    const pF=parseFloat(br[0].pct)||0;
    const pL=parseFloat(br[br.length-1].pct)||0;
    const d=+(pL-pF).toFixed(1);
    const tAll=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const aAll=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const avg=tAll>0?+((aAll/tAll)*100).toFixed(1):0;
    summaryRows.push([b,br.length,pF,pL,d,avg,d>0?'تحسّن ✅':d<0?'تراجع ❌':'ثابت ➡️']);
  });
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(summaryRows),'ملخص المقارنة');

  // ═══ ورقة تفصيلية لكل فرع ═══
  targetBranches.forEach(b=>{
    const br=reports.filter(r=>r.branch===b);
    br.sort((a,x)=>(a.createdAt?.seconds||0)-(x.createdAt?.seconds||0));
    const shName=('مقارنة-'+b).slice(0,31);
    const tAll=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const aAll=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const avg=tAll>0?+((aAll/tAll)*100).toFixed(1):0;
    const pF=parseFloat(br[0].pct)||0, pL=parseFloat(br[br.length-1].pct)||0;
    const d=+(pL-pF).toFixed(1);

    const rows=[
      ['فرع: '+b,'','','','','',''],
      ['عدد التقارير',br.length,'المتوسط الكلي',avg+'%','','',''],
      ['أول نسبة',pF+'%','آخر نسبة',pL+'%','التغيير',(d>0?'+':'')+d+'%',''],
      ['','','','','','',''],
      ['#','المندوب','النسبة %','الإجمالي','العربي','التغيير عن السابق','التاريخ']
    ];
    br.forEach((r,i)=>{
      const pp=parseFloat(r.pct)||0;
      const prev=i>0?parseFloat(br[i-1].pct)||0:null;
      const chg=prev!==null?+(pp-prev).toFixed(1):'—';
      rows.push([i+1,r.agent,pp,r.total,r.arabi,chg,r.timestamp]);
    });

    // أقسام أول vs آخر
    const secsFirst=br[0].sections||[], secsLast=br[br.length-1].sections||[];
    const allLbls=[...new Set([...secsFirst.map(s=>s.label),...secsLast.map(s=>s.label)])];
    if(allLbls.length){
      rows.push(['','','','','','','']);
      rows.push(['— مقارنة الأقسام: أول تقرير vs آخر تقرير —','','','','','','']);
      rows.push(['القسم','نسبة قبل %','نسبة بعد %','الفرق','الاتجاه','','']);
      allLbls.forEach(lbl=>{
        const sf=secsFirst.find(s=>s.label===lbl)||{count:0,arabi:0};
        const sl=secsLast.find(s=>s.label===lbl)||{count:0,arabi:0};
        const pf=sf.count>0?+((sf.arabi/sf.count)*100).toFixed(1):0;
        const pl=sl.count>0?+((sl.arabi/sl.count)*100).toFixed(1):0;
        const dd=+(pl-pf).toFixed(1);
        rows.push([lbl,pf,pl,dd,dd>0?'تحسّن':dd<0?'تراجع':'ثابت','','']);
      });
    }
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),shName);
  });

  const fname=`المقارنة_${selVal==='__ALL__'?'كل_الفروع':selVal}_${new Date().toLocaleDateString('ar-EG').replace(/\//g,'-')}.xlsx`;
  XLSX.writeFile(wb,fname);
  showToast(`تم تحميل Excel المقارنة — ${targetBranches.length} فرع ✓`);
}

