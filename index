                <span class="cmp-bar-label" style="color:#f87171">قبل</span>
                <div class="cmp-bar-track"><div class="cmp-bar-fill-b" style="width:${(parseFloat(s.pb)/maxSecPct)*100}%"></div></div>
                <span style="font-size:10px;font-weight:700;color:#f87171;min-width:32px">${s.pb}%</span>
              </div>
              <div class="cmp-bar-row">
                <span class="cmp-bar-label" style="color:#34d399">بعد</span>
                <div class="cmp-bar-track"><div class="cmp-bar-fill-a" style="width:${(parseFloat(s.pa)/maxSecPct)*100}%"></div></div>
                <span style="font-size:10px;font-weight:700;color:#34d399;min-width:32px">${s.pa}%</span>
              </div>
