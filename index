let db=null, reports=[], unsubscribe=null;
let charts={bar:null,donut:null,branchBar:null,branchDonut:null,statsLine:null,statsBar:null};
let currentPage='overview', selectedBranch=null;

// ══════════════════════════════════════════
// Firebase
// ══════════════════════════════════════════
function initFirebase(){
  try{
    firebase.initializeApp(firebaseConfig);
    db=firebase.firestore();
    setFbStatus('connecting');
    startListener();
  }catch(e){
    setFbStatus('error');
    loadFromLocalStorage();
  }
}
function setFbStatus(state){
  const dot=document.getElementById('fbDot'),txt=document.getElementById('fbStatusTxt');
  if(state==='ok'){dot.className='fb-dot ok';txt.textContent=' متصل ✓';txt.style.color='#34d399';}
  else if(state==='error'){dot.className='fb-dot err';txt.textContent='غير متصل — وضع محلي';txt.style.color='#f87171';}
  else{dot.className='fb-dot';txt.textContent='جاري الاتصال...';txt.style.color='';}
}
function startListener(){
  unsubscribe=db.collection('reports').onSnapshot(
    snap=>{
      reports=[];
      snap.forEach(doc=>reports.push({_docId:doc.id,...doc.data()}));
      reports.sort((a,b)=>(b.createdAt?.seconds||0)-(a.createdAt?.seconds||0));
      setFbStatus('ok');
      updateBadges();
      renderCurrentPage();
    },
    err=>{ setFbStatus('error'); loadFromLocalStorage(); }
  );
}
function loadFromLocalStorage(){
  try{reports=JSON.parse(localStorage.getItem('arabi_reports')||'[]').map(r=>({_docId:null,...r}));}catch(e){reports=[];}
  updateBadges();
  renderCurrentPage();
}
function updateBadges(){
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  document.getElementById('navBadgeReports').textContent=reports.length;
  document.getElementById('navBadgeBranches').textContent=branches.length;
}

// ══════════════════════════════════════════
// Navigation
// ══════════════════════════════════════════
