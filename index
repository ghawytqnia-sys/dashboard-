// عرض شامل — كل الفروع قبل وبعد
// ══════════════════════════════════════════
function renderAllBranchesFullReport(){
  const res=document.getElementById('cmpResult');
  if(!res)return;
  const branches=[...new Set(reports.map(r=>r.branch).filter(Boolean))];
  const cmpBranches=branches.filter(b=>reports.filter(r=>r.branch===b).length>=2);

  if(!cmpBranches.length){
    res.innerHTML=`<div class="no-data-cmp fi" style="padding:40px;text-align:center"><div class="ei">📊</div><h3>لا توجد فروع بتقارير متعددة بعد</h3></div>`;
    return;
  }

  // حساب إجمالي التحسن لكل الفروع
  const allStats=cmpBranches.map(b=>{
    const br=reports.filter(r=>r.branch===b);
    br.sort((a,x)=>(a.createdAt?.seconds||0)-(x.createdAt?.seconds||0));
    const first=br[0], last=br[br.length-1];
    const pF=parseFloat(first?.pct)||0, pL=parseFloat(last?.pct)||0;
    const d=+(pL-pF).toFixed(1);
    const totalF=br.reduce((s,r)=>s+(Number(r.total)||0),0);
    const arabiF=br.reduce((s,r)=>s+(Number(r.arabi)||0),0);
    const avgPct=totalF>0?+((arabiF/totalF)*100).toFixed(1):0;
    return{b, br, first, last, pF, pL, d, len:br.length, totalF, arabiF, avgPct};
  }).sort((a,x)=>x.d-a.d);

  const improved=allStats.filter(s=>s.d>0).length;
  const declined=allStats.filter(s=>s.d<0).length;
  const stable=allStats.filter(s=>s.d===0).length;
  const bestBranch=allStats[0];
  const worstD=allStats.filter(s=>s.d<0).sort((a,b)=>a.d-b.d)[0];

  res.innerHTML=`
    <div class="fi" style="margin-bottom:22px">
      <!-- ═══ لوحة الملخص الإجمالي ═══ -->
      <div style="background:linear-gradient(135deg,rgba(14,165,233,.1),rgba(6,182,212,.06));border:1px solid rgba(14,165,233,.3);border-radius:var(--r);padding:20px 22px;margin-bottom:20px;">
